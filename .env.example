# --- SportsGameOdds API ---
# Get a key at https://sportsgameodds.com
SPORTSGAMEODDS_API_KEY=

# --- Streak alerts (Resend) ---
# Get a free API key at https://resend.com/api-keys
RESEND_API_KEY=
# Recipient of streak alerts. Comma-separate for multiple, e.g. a@x.com,b@y.com
ADMIN_EMAIL=
# Optional. Free-tier default works without a verified domain.
# ALERT_FROM=Fade The Money <onboarding@resend.dev>

# --- /api/refresh protection ---
# Optional. If set, POST /api/refresh requires Authorization: Bearer <token>.
REFRESH_TOKEN=

# --- Accounts + admin (Supabase) — Phase 2 ---
# Create a free project at https://supabase.com, then:
#   Project Settings → API → Project URL / anon public key / service_role key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-ONLY. Never expose to the browser. Used for role changes / deletes.
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated emails treated as super admins (env-pinned bootstrap).
SUPER_ADMIN_EMAILS=robert@doctorautoglass.com

# --- Persistent storage (production only) ---
# When this is set, the app reads/writes data/store.json from Vercel Blob
# instead of the local filesystem (Vercel functions have an ephemeral
# filesystem). Get this from: Vercel dashboard → Storage → Blob → connect
# your project. Vercel injects it automatically once connected.
# Leave UNSET in local dev to use the local file.
BLOB_READ_WRITE_TOKEN=
